<div class="row">
  <div class="col-lg-12">
    <div class="page-header">
      <h1>Newsletter sign-up</h1>
      <h3>Get email updates from New Internationalist. Enter your email address below to join the newsletter.</h3>
    </div>

    <div>
      <div>
        <%= simple_form_for @newsletter_signup, url: newsletter_path, html: { class: "form-horizontal" } do |f| %>
          <% f.error_notification %>

          <div class="inputs">
            <%= f.input :email,
              required: true,
              autofocus: true,
              input_html: {
                autocomplete: "email",
                placeholder: "you@example.com"
              } %>
          </div>

          <div class="actions">
            <%= f.button :submit, "Sign up", class: "btn btn-success" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
